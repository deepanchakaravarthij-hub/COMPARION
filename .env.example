COMPARION_APP_NAME=COMPARION API
COMPARION_ENVIRONMENT=local
COMPARION_LOG_LEVEL=INFO
COMPARION_MAX_UPLOAD_MB=50
COMPARION_DATABASE_URL=sqlite:///storage/comparion.db
COMPARION_STORAGE_ROOT=storage
COMPARION_REDIS_URL=redis://localhost:6379/0
COMPARION_STORAGE_ENDPOINT=http://localhost:9000
COMPARION_STORAGE_BUCKET=comparion
COMPARION_PREPROCESSING_ENABLED=true
COMPARION_OCR_ENABLED=true
COMPARION_OCR_ADAPTER=none
COMPARION_OCR_CONFIDENCE_THRESHOLD=0.6
COMPARION_OCR_LANGUAGE=en
COMPARION_ALIGNMENT_ENABLED=true
COMPARION_ECC_ALIGNMENT_ENABLED=false
POSTGRES_USER=comparion
POSTGRES_PASSWORD=comparion
POSTGRES_DB=comparion
MINIO_ROOT_USER=comparion
MINIO_ROOT_PASSWORD=comparion-secret
